{
  "name": "finpath",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "build": "npm run build --workspace frontend",
    "build:all": "npm run build",
    "start": "npm run start --workspace backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
